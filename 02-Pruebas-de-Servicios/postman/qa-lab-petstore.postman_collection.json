				{
					"listen": "test",
					"script": {
						"exec": [
							"// Obtener información de la respuesta y almacenarla en una variable del Environment\r",
							"let respuesta = pm.response.json()\r",
							"pm.environment.set(\"idMascota\",respuesta.id)\r",
							"\r",
							"// Generar un test para verificar que el status code es 200.\r",
							"let statusCodeRecibido = pm.response.code // devuelve el código de respuesta\r",
							"let statusRecibido = pm.response.status // devuelve la descripción de la respuesta\r",
							"\r",
							"pm.test(\"Valida el status code es 200 cuando se envía un ID largo\", function () {\r",
							"    pm.expect(pm.response.code).to.equal(200);\r",
							"});\r",
							"\r",
							"pm.test(\"Validar el ID generado de la mascota\", function () {\r",
							"    pm.expect(pm.response.json()).to.be.an('object');\r",
							"    pm.expect(pm.response.json().id).to.be.a('number');\r",
							"    pm.expect(pm.response.json().id).to.be.above(0, \"ID should be a positive number\");\r",
							"});"
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
